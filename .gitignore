# Virtual environment
.venv/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# OS files
.DS_Store
Thumbs.db

# IDE settings
.vscode/
.idea/

# Claude Code -- keep shared subagents/commands/CLAUDE.md tracked.
# Ignore only local state: personal permissions, worktrees, local-scope agent memory.
.claude/settings.local.json
.claude/worktrees/
.claude/agent-memory-local/
CLAUDE.local.md

# Generated by toolkit (device scans)
devices.json
devices.py

# REPL saved scripts — belongs in the user's personal repo, not here
.repl_scripts.json

# Lab data generated by users (keep out of toolkit repo)
*.csv
*.png
*.xlsx

# MkDocs generated site — built by mkdocs build, deployed by mkdocs gh-deploy.
# These are build artifacts; the canonical site lives on the gh-pages branch.
/site/
lab_instruments/site/
lab_instruments/site-library/

# pytest / coverage artifacts
.coverage
htmlcov/
.pytest_cache/

# Testing lab shit
.testing-labs/
